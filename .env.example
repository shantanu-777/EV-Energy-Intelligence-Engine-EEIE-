# EEIE environment configuration. Copy to `.env` and adjust as needed.

# --- Postgres / TimescaleDB ---
POSTGRES_USER=eeie
POSTGRES_PASSWORD=eeie_dev_password
POSTGRES_DB=eeie
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# DSN used by the application. When running services in Docker Compose,
# the host is the service name (`timescaledb`). For local CLI runs against
# the same compose stack, set POSTGRES_HOST=localhost.
EEIE_DATABASE_URL=postgresql+psycopg://eeie:eeie_dev_password@timescaledb:5432/eeie

# --- API ---
EEIE_API_HOST=0.0.0.0
EEIE_API_PORT=8000
EEIE_API_LOG_LEVEL=info

# --- UI ---
EEIE_UI_PORT=8501
# URL the Streamlit UI uses to reach the API. Use http://api:8000 inside Compose,
# http://localhost:8000 from the host machine.
EEIE_API_BASE_URL=http://api:8000

# --- Currency (public datasets occasionally publish USD totals) ---
EEIE_USD_TO_EUR=0.92

# --- Paths ---
EEIE_DATA_DIR=./data
EEIE_CHECKPOINT_DIR=./checkpoints

# --- Simulation defaults ---
EEIE_SIM_VEHICLES=100
EEIE_SIM_MONTHS=12
EEIE_SIM_SEED=42

# --- Optimization ---
# Which charging optimizer to use when calling /optimize_charging.
# One of: "milp", "rl"
EEIE_OPTIMIZER=milp
